rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAllowedEmail() {
      return isSignedIn()
        && request.auth.token.email in [
          "bestfriendpakminji@gmail.com",
          "admin@bubbit.com",
          "member@bubbit.com"
        ];
    }

    match /{document=**} {
      allow read, write: if isAllowedEmail();
    }
  }
}
